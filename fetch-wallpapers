#!/usr/bin/env python3
# python3: the duct tape of the internet
import json, os, urllib.request, sys, random
from urllib.parse import urlparse, unquote

# source: the eternal question
source = sys.argv[1] if len(sys.argv) > 1 else "random"
# make way for wallpapers!
cache_dir = os.path.expanduser("~/.config/quickshell/lazerbar/wallpapers")
os.makedirs(cache_dir, exist_ok=True)

wallpaper = None

# stealing wallpapers from rhythm gamers
if source in ("osu", "random"):
    try:
        resp = urllib.request.urlopen("https://osu.ppy.sh/api/v2/seasonal-backgrounds", timeout=10)
        data = json.loads(resp.read())
        bgs = data.get("backgrounds", [])
        if bgs:
            # the fate of your desktop, decided by rand()
            bg = random.choice(bgs)
            url = bg["url"]
            parsed = urlparse(url)
            filename = unquote(os.path.basename(parsed.path))
            filepath = os.path.join(cache_dir, filename)
            if not os.path.exists(filepath):
                # moments later, in the downloads folder...
                img = urllib.request.urlopen(url, timeout=15)
                with open(filepath, "wb") as f:
                    f.write(img.read())
            wallpaper = {"file": filepath, "url": url, "artist": bg.get("user", {}).get("username", "unknown"), "source": "osu"}
    except:
        # silent failure: the python way
        pass

# plan B: questionable anime art
if not wallpaper and source in ("konachan", "random"):
    try:
        req = urllib.request.Request(
            # we promise it's work-safe (probably)
            "https://konachan.com/post.json?limit=30&tags=rating%3Asafe+order%3Arandom",
            # introducing ourselves like a polite robber
            headers={"User-Agent": "lazerbar/1.0"}
        )
        resp = urllib.request.urlopen(req, timeout=10)
        posts = json.loads(resp.read())
        if posts:
            # random: the only algorithm we trust
            post = random.choice(posts)
            img_url = post.get("jpeg_url") or post.get("file_url")
            if img_url:
                parsed = urlparse(img_url)
                filename = unquote(os.path.basename(parsed.path))
                filepath = os.path.join(cache_dir, filename)
                if not os.path.exists(filepath):
                    req_img = urllib.request.Request(img_url, headers={"User-Agent": "lazerbar/1.0"})
                    img = urllib.request.urlopen(req_img, timeout=15)
                    with open(filepath, "wb") as f:
                        f.write(img.read())
                # giving credit where credit is... probably due
                wallpaper = {"file": filepath, "url": img_url, "artist": post.get("author", "unknown"), "source": "konachan"}
    except:
        pass

if wallpaper:
    # wallpaper acquired. your desktop is safe. for now.
    result = json.dumps(wallpaper)
    print(result)
    sys.exit(0)
else:
    # wallpaper not found. time to touch grass.
    sys.exit(1)
